{
  "$schema": "https://schema.zeabur.app/template.json",
  "build_type": "static",
  "build_command": "npm install --legacy-peer-deps && npm run build",
  "output_dir": "dist",
  "routes": [
    { "src": "/privacy.html", "dest": "/privacy.html" },
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/terms.html", "dest": "/terms.html" },
    { "src": "/terms", "dest": "/terms.html" }
  ]
}
