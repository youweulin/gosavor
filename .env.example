# GoSavor Environment Variables

# Gemini API Key (for rental mode / server-side)
VITE_GEMINI_API_KEY=

# Firebase Configuration (legacy)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudflare Worker URL (Gemini proxy with system key)
VITE_WORKER_URL=https://gosavor-api.your-account.workers.dev

# Supabase
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
